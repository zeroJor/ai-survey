APP_NAME="Web Interviewer"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# E0.2 — Docker MySQL (docker compose up -d)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=web_interviewer
DB_USERNAME=web_interviewer
DB_PASSWORD=secret

SESSION_DRIVER=database
# ~7 days (minutes); sliding refresh implemented in F2 (E2.1)
SESSION_LIFETIME=10080
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# F8 (E8.1) — email
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hola@idwasoft.com"
MAIL_FROM_NAME="${APP_NAME}"

# F5 (E5.1) — Google OAuth admin (Web client; redirect URI must match exactly)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
# ADMIN_ALLOWED_EMAIL_DOMAIN=idwasoft.com

# Local/testing: email + password login at /admin (seed: dev@idwasoft.com / password)
ADMIN_PASSWORD_LOGIN=true

# F2 (E2.1) — invite action JWT
ACTION_JWT_SECRET=

# F7 (E7.1) — Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
LLM_TIMEOUT_SECONDS=25

# F2 (E2.1) — interview session cookie name
INTERVIEW_SESSION_COOKIE=interview_session
INTERVIEW_SESSION_TTL_DAYS=7
ACTION_JWT_TTL_DAYS=7

# E0.3 — Sanctum SPA (same-origin)
SANCTUM_STATEFUL_DOMAINS=127.0.0.1:8000,localhost:8000,127.0.0.1:5173,localhost:5173

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
